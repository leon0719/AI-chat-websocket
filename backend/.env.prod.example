# ==================================
# Production Environment
# 生產環境設定
# ==================================
# 複製此檔案為 .env.prod 並填入實際值
# cp .env.prod.example .env.prod

# ===================
# Environment
# ===================
ENV=prod
DJANGO_SETTINGS_MODULE=config.settings.prod

# ===================
# Required Settings
# ===================

# Django
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# Database (請使用正式環境的資料庫連線)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (請使用正式環境的 Redis 連線)
REDIS_URL=redis://host:6379/0

# OpenAI
OPENAI_API_KEY=

# JWT
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# ===================
# Production Settings
# ===================

DEBUG=false
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# JWT Token 有效期 (生產環境建議縮短)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===================
# ECPay Payment (正式環境)
# ===================
# 正式環境請使用專屬帳號，禁止使用測試帳號
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_PAYMENT_URL=https://payment.ecpay.com.tw/Cashier/AioCheckOut/V5
# ReturnURL 須為公開可訪問的 HTTPS URL（僅支援 port 80/443，不可放在 CDN 後方）
ECPAY_RETURN_URL=https://your-domain.com/api/payments/ecpay/notify
# 付款完成後瀏覽器跳轉回的前端頁面
ECPAY_CLIENT_BACK_URL=https://your-frontend-domain.com/top-up
