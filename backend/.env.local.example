# ==================================
# Local Development Environment
# Docker 本地開發環境設定
# ==================================
# 複製此檔案為 .env.local 並填入實際值
# cp .env.local.example .env.local

# ===================
# Environment
# ===================
ENV=local
DJANGO_SETTINGS_MODULE=config.settings.local

# ===================
# Required Settings
# ===================

# Django
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# Database (Docker 容器內部連線)
DATABASE_URL=postgresql://chatbot:chatbot@db:5432/chatbot

# Redis (Docker 容器內部連線)
REDIS_URL=redis://redis:6379/0

# OpenAI
OPENAI_API_KEY=

# JWT
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# ===================
# Optional Settings
# ===================

DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Token 有效期
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===================
# ECPay Payment (測試環境)
# ===================
# 以下為公開共用測試帳號，所有開發者共用
ECPAY_MERCHANT_ID=3002607
ECPAY_HASH_KEY=pwFHCqoQZGmho4w6
ECPAY_HASH_IV=EkRm7iFT261dpevs
ECPAY_PAYMENT_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5
# ReturnURL 須為公開可訪問的 HTTPS URL（僅支援 port 80/443）
# 本地開發請用 ngrok: ngrok http 8000 → 將產生的 URL 填入
ECPAY_RETURN_URL=
# 付款完成後瀏覽器跳轉回的前端頁面
ECPAY_CLIENT_BACK_URL=http://localhost:5173/top-up
